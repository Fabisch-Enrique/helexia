          <div class="absolute -right-20 -top-32 h-96 w-96 rounded-full bg-sky-500/25 blur-3xl">
          </div>

          <div class="absolute -bottom-40 left-1/3 h-80 w-80 rounded-full bg-emerald-400/15 blur-3xl">
