        class="about-cta-shimmer relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-cyan-700 via-[#087890] to-blue-800 px-7 py-16 text-center text-white shadow-2xl shadow-cyan-900/20 sm:px-12 sm:py-20"
