        <article
          data-reveal="scale"
          data-pointer-glow
          style="--reveal-delay: 240ms;"
          class="about-interactive-card group rounded-[2rem] border border-slate-200 bg-[#f8fbfc] p-8 transition duration-500 hover:-translate-y-2 hover:border-violet-300 hover:bg-white hover:shadow-2xl hover:shadow-violet-950/10"
        >
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-violet-100 text-violet-700 transition duration-500 group-hover:-rotate-3 group-hover:scale-110">
